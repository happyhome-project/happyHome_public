{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "for /f \"delims=\" %i in ('git rev-parse --show-toplevel') do @node \"%i\\scripts\\worktree.mjs\" heartbeat --provider=claude --quiet",
            "timeout": 10
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "for /f \"delims=\" %i in ('git rev-parse --show-toplevel') do @node \"%i\\scripts\\worktree.mjs\" heartbeat --provider=claude --quiet",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
