{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue",
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": { "navigationBarTitleText": "社群助手", "enablePullDownRefresh": true }
    },
    {
      "path": "pages/search/index",
      "style": { "navigationBarTitleText": "搜索", "navigationStyle": "custom" }
    },
    {
      "path": "pages/create/index",
      "style": { "navigationBarTitleText": "发帖" }
    },
    {
      "path": "pages/profile/index",
      "style": { "navigationBarTitleText": "我的", "enablePullDownRefresh": true }
    },
    {
      "path": "pages/detail/index",
      "style": { "navigationBarTitleText": "详情" }
    },
    {
      "path": "pages/section/index",
      "style": { "navigationBarTitleText": "板块" }
    },
    {
      "path": "pages/notice/index",
      "style": { "navigationBarTitleText": "公告详情" }
    },
    {
      "path": "pages/onboarding/index",
      "style": { "navigationBarTitleText": "加入社区", "enablePullDownRefresh": true }
    },
    {
      "path": "pages/createCommunity/index",
      "style": { "navigationBarTitleText": "创建社区" }
    },
    {
      "path": "pages/web-view/index",
      "style": { "navigationBarTitleText": "外部链接" }
    },
    {
      "path": "pages/admin-login/index",
      "style": { "navigationBarTitleText": "管理后台登录" }
    }
  ],
  "tabBar": {
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/tab-home.png",
        "selectedIconPath": "static/tab-home-active.png"
      },
      {
        "pagePath": "pages/create/index",
        "text": "发帖",
        "iconPath": "static/tab-add.png",
        "selectedIconPath": "static/tab-add-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "static/tab-profile.png",
        "selectedIconPath": "static/tab-profile-active.png"
      }
    ],
    "color": "#88918C",
    "selectedColor": "#3DAD7D",
    "backgroundColor": "#FFFFFF"
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "社群助手",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F6F7F9"
  }
}
